# 20/20 Game -- Environment Variables
# Copy to .env for local dev (never commit .env)

# Flask
FLASK_APP=api/app.py
FLASK_ENV=development

# Admin secret for /api/generate and /api/generate/batch
# Change this to something strong in production
ADMIN_SECRET=dev_secret

# Optional: override the puzzles directory
# PUZZLE_DIR=/absolute/path/to/puzzles

# Puzzle generation defaults (used by the API when auto-generating)
# sport_mode: NFL / NBA / MLB / NHL / ALL / NFL,NBA / etc.
SPORT_MODE=NFL
# difficulty: easy / medium / hard / any
PUZZLE_DIFFICULTY=medium

# Public base URL -- used in share card links (no trailing slash)
# Set this to your domain once you have one
SITE_URL=http://localhost:5902

# CollegeFootballData API key for the NCAAF data run (run_full.py / cfbd_export.py)
# Get one free at https://collegefootballdata.com/key
CFBD_API_KEY=

# Puzzle length: 20 in production; lower (e.g. 10) for a small offline demo
# PUZZLE_CHAIN_LENGTH=20

# --- Sports-Reference backfill / history crawler (all optional) ---
# Only used by data/etl/backfill_sr.py and data/etl/sr_history.py. You only need
# the cookie for SR zones that throw Cloudflare's "Just a moment..." challenge
# (pro-football-reference); basketball-/hockey-reference usually don't.
#
# cf_clearance value copied from a browser that passed the challenge
# (DevTools -> Application -> Cookies). It's a secret -- keep it here, not in
# source -- and is bound to that browser's IP + User-Agent.
# SR_CF_CLEARANCE=
# Exact User-Agent the cookie was issued to. Defaults to a hardcoded Chrome
# string; set this only if your Chrome version differs from it.
# SR_CF_UA=
# Polite contact string sent as the From: header on SR requests (optional).
# SR_CONTACT=you@example.com
